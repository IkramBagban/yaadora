# Yaadora environment. Copy to `.env` (Bun auto-loads it — do NOT add dotenv).
# Do not commit real secrets.

# --- Infra (spec 01 §6) ---
# Matches docker-compose.yml (user/pass/db = yaadora).
DATABASE_URL="postgres://yaadora:yaadora@localhost:5432/yaadora"
REDIS_URL="redis://localhost:6379"

# --- AI providers (packages/core/ai/models.ts) ---
# Provider selector: groq | google | openai | antigravity
# Prod default in code is "groq". Switch locally without code changes.
#   openai      → GPT via OPENAI_BASE_URL (CLIProxy) or official OpenAI API
#   antigravity → Gemini via CLIProxy (Google Antigravity subscription)
AI_PROVIDER="groq"

# Provider keys (comma-separated list = auto key rotation on 429)
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
GROQ_API_KEY=""

# OpenAI-compatible endpoint (official OpenAI OR local CLIProxyAPI)
# For local subsidized models via CLIProxyAPI:
#   AI_PROVIDER=openai|antigravity
#   OPENAI_BASE_URL=http://127.0.0.1:8317/v1
#   OPENAI_API_KEY=<cliproxy local key>
# Leave OPENAI_BASE_URL empty with openai to use https://api.openai.com/v1
OPENAI_API_KEY=""
# OPENAI_BASE_URL=""
# Optional per-tier model overrides (any provider):
# AI_MODEL_INGESTION="gemini-3.1-flash-lite"
# AI_MODEL_REASONING="gemini-3.1-pro-low"
# AI_MODEL_FAST="gemini-3.1-flash-lite"
# Embeddings never use OPENAI_BASE_URL; override host only if needed:
# OPENAI_EMBEDDING_BASE_URL="https://api.openai.com/v1"

# --- Speech-to-text (voice capture) ---
# Reuses GROQ_API_KEY above. Comma-separate multiple keys to fail over on 429:
#   GROQ_API_KEY="key_1,key_2,key_3"
# Keys rotate on rate-limit / invalid-key errors and the cursor sticks to the
# one that worked. When every key is spent the server returns 503 and the mobile
# client falls back to on-device recognition instead of showing an error.
# Optional model override (default: whisper-large-v3-turbo — ~228x realtime,
# free-tier eligible). whisper-large-v3 is slower but better on hard audio.
# GROQ_TRANSCRIPTION_MODEL="whisper-large-v3"

# --- Auth (Clerk + optional bootstrap for seed/eval) ---
# Product path: Clerk session JWTs (Authorization: Bearer <session JWT>).
CLERK_SECRET_KEY=""                     # from Clerk Dashboard → API keys
CLERK_PUBLISHABLE_KEY=""                # optional on server; required on mobile as EXPO_PUBLIC_
# CLERK_JWT_KEY=""                      # optional PEM public key for networkless verify

# Bootstrap: local seed/eval ONLY. Never enable on a public VM.
# AUTH_ALLOW_BOOTSTRAP="true"
# AUTH_BOOTSTRAP_TOKEN="change-me-dev-token"
# SEED_USER_EMAIL="owner@yaadora.local"
# SEED_USER_TIMEZONE="UTC"

# --- Retrieval tuning ---
# LLM rerank pass in search_memories. OFF by default: it is a second fastModel
# round-trip on EVERY search, and the Ask agent may search several times per
# turn. Disabled, results are ordered by the fused hybrid retrieval score.
# Turn on to trade latency for precision (and for a calibrated `confidence`).
# RERANK_ENABLED=true

# --- Tuning (optional) ---
PORT="3000"                             # server port
INGESTION_CONCURRENCY="5"               # worker concurrency
# Redis free tiers cap client count. WORKER_MINIMAL=true (default in dev) starts
# only ingestion + consolidation workers (~4–6 Redis connections instead of ~12+).
# WORKER_MINIMAL=false
# WORKER_ENABLE_REPROCESS=true
# WORKER_ENABLE_CONVERSATION_MAINTENANCE=true
# WORKER_ENABLE_PROSPECTION=true

# Embeddings: openai (text-embedding-3-small) or google (gemini-embedding-001 @1536).
# Switching requires re-embedding everything.
EMBEDDING_PROVIDER=openai
