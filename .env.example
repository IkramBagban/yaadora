# Yaadora environment. Copy to `.env` (Bun auto-loads it — do NOT add dotenv).
# Do not commit real secrets.

# --- Infra (spec 01 §6) ---
# Matches docker-compose.yml (user/pass/db = yaadora).
DATABASE_URL="postgres://yaadora:yaadora@localhost:5432/yaadora"
REDIS_URL="redis://localhost:6379"

# --- AI providers (spec 02 §1) ---
# Provider tier selector: anthropic | google
AI_PROVIDER="anthropic"

# Reasoning + ingestion tiers
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Embeddings (dedicated provider; dimension fixed at 1536)
OPENAI_API_KEY=""

# --- Auth (server, spec 03 §1.4) ---
# Static bootstrap bearer token for the single seeded user. Send as
# `Authorization: Bearer <token>`. Multi-user auth is a later drop-in.
AUTH_BOOTSTRAP_TOKEN="change-me-dev-token"
SEED_USER_EMAIL="owner@yaadora.local"   # optional; default owner@yaadora.local
SEED_USER_TIMEZONE="UTC"                # optional; IANA tz for temporal resolution

# --- Tuning (optional) ---
PORT="3000"                             # server port
INGESTION_CONCURRENCY="5"               # worker concurrency

# Embeddings: openai (text-embedding-3-small) or google (gemini-embedding-001 @1536).
# Switching requires re-embedding everything.
EMBEDDING_PROVIDER=openai
