# Mobile env (Expo). Copy to apps/mobile/.env
#
# localhost is fine for iOS Simulator. On Android emulator the app rewrites
# localhost → 10.0.2.2 automatically. Physical devices need your Mac's LAN IP:
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
